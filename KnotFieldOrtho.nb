Notebook[{
Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
  "Let", " ", "us", " ", "verify", " ", "if", " ", "any", " ", "two", " ", 
   "knots", " ", "are", " ", "orthogonal", " ", "from", " ", "their", " ", 
   "fields", " ", "generated", " ", "from", " ", "the", " ", "Milnor", " ", 
   "polynomial"}], " ", "*)"}]], "Input",
 CellChangeTimes->{{3.919504751061886*^9, 
  3.919504823376466*^9}},ExpressionUUID->"e4a3c05f-df85-4260-a97c-\
fba4e18a5711"],

Cell[CellGroupData[{

Cell["Define the numerical field ", "Subsection",
 CellChangeTimes->{{3.9195054071068773`*^9, 3.9195054343418555`*^9}, {
  3.9195057372258673`*^9, 
  3.9195057453483686`*^9}},ExpressionUUID->"c9319278-8bc8-4147-95a2-\
5f42269c5276"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"um", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "6"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mm", " ", "=", " ", 
   SuperscriptBox["10", 
    RowBox[{"-", "3"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxN", " ", "=", " ", "128"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"maxx", " ", "=", " ", 
   RowBox[{"20", "*", "um", "*", "maxN"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dx", " ", "=", " ", 
   RowBox[{"maxx", "/", "maxN"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dy", " ", "=", " ", 
    RowBox[{"maxx", "/", "maxN"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"X", " ", "=", " ", 
   RowBox[{"dx", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Range", "[", "maxN", "]"}], " ", "-", " ", 
      RowBox[{"Mod", "[", 
       RowBox[{"maxN", ",", "2"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Y", " ", "=", " ", 
   RowBox[{"dy", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Range", "[", "maxN", "]"}], "-", " ", 
      RowBox[{"Mod", "[", 
       RowBox[{"maxN", ",", "2"}], "]"}]}], ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.919505445203373*^9, 3.9195054982126503`*^9}, {
  3.9195055351933165`*^9, 3.9195056726656127`*^9}, {3.9195057063763895`*^9, 
  3.919505721665686*^9}, {3.919505798720792*^9, 3.919505847106954*^9}, {
  3.9195059154742947`*^9, 3.9195059275301476`*^9}},
 CellLabel->"In[47]:=",ExpressionUUID->"a503a64c-aa2e-4471-b3d6-4abdfb43ce9f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Wait ... we\[CloseCurlyQuote]re in Mathematica Land, so I can just define the \
field explicitly!\
\>", "Subsection",
 CellChangeTimes->{{3.9195058575881767`*^9, 
  3.919505878598153*^9}},ExpressionUUID->"d4964e97-2745-4c86-b321-\
e0baf475840c"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"w0", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Rho]", "[", "r_", "]"}], " ", ":=", " ", 
     RowBox[{"r", "/", "w0"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[Psi]", "Trefoil"], "[", 
      RowBox[{
      "a_", ",", " ", "b_", ",", " ", "s_", ",", "r_", ",", " ", "\[Phi]_"}], 
      " ", "]"}], ":=", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "2"]}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", 
          SuperscriptBox["s", "2"]}], ")"}]}], "]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "4"}], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Rho]", "[", "r", "]"}], ")"}], "3"], 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["a", "2"], " ", "-", " ", 
           SuperscriptBox["b", "2"]}], ")"}]}], " ", "-", " ", 
        RowBox[{"2", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Rho]", "[", "r", "]"}], ")"}], "3"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"a", "-", "b"}], ")"}], "2"], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "I"}], "*", "3", "\[Phi]"}], "]"}]}], " ", "-", " ", 
        RowBox[{"2", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Rho]", "[", "r", "]"}], ")"}], "3"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"a", "+", "b"}], ")"}], "2"], 
         RowBox[{"Exp", "[", 
          RowBox[{"I", "*", "3", "\[Phi]"}], "]"}]}], " ", "+", " ", 
        SuperscriptBox[
         RowBox[{"\[Rho]", "[", "r", "]"}], "6"], " ", "-", " ", 
        SuperscriptBox[
         RowBox[{"\[Rho]", "[", "r", "]"}], "4"], "-", 
        SuperscriptBox[
         RowBox[{"\[Rho]", "[", "r", "]"}], "2"], "+", "1"}], ")"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[Psi]", "Cinquefoil"], "[", 
      RowBox[{
      "a_", ",", " ", "b_", ",", " ", "s_", ",", "r_", ",", " ", "\[Phi]_"}], 
      " ", "]"}], ":=", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "2"]}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", 
          SuperscriptBox["s", "2"]}], ")"}]}], "]"}], "*", " ", 
      RowBox[{"(", 
       RowBox[{"1", " ", "+", " ", 
        SuperscriptBox[
         RowBox[{"\[Rho]", "[", "r", "]"}], "2"], " ", "-", " ", 
        RowBox[{"2", 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "4"]}], "-", 
        RowBox[{"2", 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "6"]}], " ", "+", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "8"], 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "10"]}], " ", "-", " ", 
        RowBox[{"16", 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "5"], 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox["a", "2"], "-", 
           SuperscriptBox["b", "2"]}], ")"}]}], "-", 
        RowBox[{"8", 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "5"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"a", "-", "b"}], ")"}], "2"], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "I"}], "*", "5", "\[Phi]"}], "]"}]}], " ", "-", "  ", 
        RowBox[{
         RowBox[{"-", "8"}], 
         SuperscriptBox[
          RowBox[{"\[Rho]", "[", "r", "]"}], "5"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"a", "+", "b"}], ")"}], "2"], 
         RowBox[{"Exp", "[", 
          RowBox[{"I", "*", "5", "\[Phi]"}], "]"}]}]}], " ", ")"}]}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.919505889929522*^9, 3.9195060302890277`*^9}, {
   3.919506215171131*^9, 3.919506502756359*^9}, {3.919506560425001*^9, 
   3.9195065739867325`*^9}, {3.919506628622039*^9, 3.9195068701244426`*^9}, {
   3.919506923053374*^9, 3.9195069232468786`*^9}, {3.9195070757058463`*^9, 
   3.919507213361997*^9}, 3.9195073223989334`*^9, {3.9195073801600657`*^9, 
   3.9195073847749557`*^9}, {3.919508046349573*^9, 3.919508046479806*^9}, {
   3.919508552188573*^9, 3.9195085545544753`*^9}, {3.919508795990407*^9, 
   3.9195088058943305`*^9}},ExpressionUUID->"4f48e22d-c462-4f95-86eb-\
5840972fa0e5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Now, perform the integral ", "Subsection",
 CellChangeTimes->{{3.9195074852031646`*^9, 3.9195074929788227`*^9}, {
  3.919508050612013*^9, 
  3.9195080517675433`*^9}},ExpressionUUID->"d4c0e4f6-a952-41a3-bcf4-\
054dfdaadd9a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"innerProd", "[", 
    RowBox[{"r_", ",", " ", "\[Phi]_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Conjugate", "[", 
     RowBox[{
      SubscriptBox["\[Psi]", "Trefoil"], "[", 
      RowBox[{
      "1", ",", " ", "1", ",", " ", "1.2", ",", "r", ",", " ", "\[Phi]"}], 
      " ", "]"}], "]"}], "*", " ", 
    RowBox[{
     SubscriptBox["\[Psi]", "Cinquefoil"], "[", 
     RowBox[{
     "2.5", ",", " ", "2.5", ",", " ", "1.2", ",", "r", ",", " ", "\[Phi]"}], 
     " ", "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9195075000796237`*^9, 3.9195075906194816`*^9}},
 CellLabel->
  "In[113]:=",ExpressionUUID->"1a2d2ad2-5c57-4dc8-a84f-38749a378daf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"r", "*", 
     RowBox[{"innerProd", "[", 
      RowBox[{"r", ",", "\[Phi]"}], "]"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"r", ",", "0", ",", " ", "\[Infinity]"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Phi]", ",", "0", ",", " ", 
      RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"This", " ", ".."}], " ", 
    RowBox[{"isn", "'"}], "t", " ", "equal", " ", "to", " ", "0"}], 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.9195076329375067`*^9, 3.9195076345370607`*^9}, {
  3.9195077063039937`*^9, 3.9195078225389695`*^9}, {3.9195080390343714`*^9, 
  3.9195081022402716`*^9}, {3.91950890388505*^9, 3.9195089252515163`*^9}, {
  3.9195090018039637`*^9, 
  3.919509019229576*^9}},ExpressionUUID->"9c74afac-0c4d-4dc4-a1e1-\
