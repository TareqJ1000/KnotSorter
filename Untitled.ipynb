   "source": [
    "from optical_functions import shannon_entropy\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "secret_key_rate = lambda d,qber: np.log2(d) - 2*shannon_entropy(qber,d)\n",
    "\n",
    "error = np.linspace(0,1, num=1000)\n",
    "\n",
    "plt.plot(error, secret_key_rate(3, error))"
   ]
  },
