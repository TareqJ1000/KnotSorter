           RowBox[{"b", "^", "3"}], " ", 
           RowBox[{"\[Rho]", "^", "4"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "4", " ", "\[Phi]"}], "]"}]}], "-", 
