  "112b82ce-adff-4406-ada2-350411c2cd00"],
 "\n\nWhere s specifies the width of the gaussian envelope, and a and b are \
parameters which controls shape-specific properties of the knot. The \
wavefunctions are all defined at z=0, whereby we would apply the first phase \
hologram to the incoming field. "
}], "Text",
 CellChangeTimes->{{3.968235618103341*^9, 3.9682356895589714`*^9}, {
  3.9683219045606623`*^9, 3.9683219098568497`*^9}, {3.9683219465681176`*^9, 
  3.9683221939119487`*^9}, {3.969097058158218*^9, 
  3.969097059743631*^9}},ExpressionUUID->"36e5dd0b-8926-4ed0-8a29-\
d23ef0e54f5a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"dimensionless", " ", 
     RowBox[{"rho", ":", "\[Rho]\:0303"}]}], "=", 
    RowBox[{"r", "/", "w0"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{"\[Psi]Trefoil", ",", "\[Psi]Cinquefoil", ",", "\[Psi]Fig8"}], 
     "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[Psi]Trefoil", "[", 
       RowBox[{"a_", ",", "b_", ",", "s_", ",", 
        RowBox[{"w0_", ":", "0.001"}]}], "]"}], "[", 
      RowBox[{"r_", ",", "\[Phi]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Rho]", "=", 
         RowBox[{"r", "/", "w0"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"\[Rho]", "^", "2"}]}], "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"s", "^", "2"}]}], ")"}]}], "]"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "4"}], " ", 
           RowBox[{"\[Rho]", "^", "3"}], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"a", "^", "2"}], "-", 
             RowBox[{"b", "^", "2"}]}], ")"}]}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"\[Rho]", "^", "3"}], " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", "-", "b"}], ")"}], "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "3", " ", "\[Phi]"}], "]"}]}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"\[Rho]", "^", "3"}], " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", "+", "b"}], ")"}], "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "3", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"\[Rho]", "^", "6"}], "-", 
          RowBox[{"\[Rho]", "^", "4"}], "-", 
          RowBox[{"\[Rho]", "^", "2"}], "+", "1"}], ")"}]}]}], "]"}]}], ";"}],
    "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[Psi]Cinquefoil", "[", 
       RowBox[{"a_", ",", "b_", ",", "s_", ",", 
        RowBox[{"w0_", ":", "0.001"}]}], "]"}], "[", 
      RowBox[{"r_", ",", "\[Phi]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Rho]", "=", 
         RowBox[{"r", "/", "w0"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"\[Rho]", "^", "2"}]}], "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"s", "^", "2"}]}], ")"}]}], "]"}], "*", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"\[Rho]", "^", "2"}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"\[Rho]", "^", "4"}]}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"\[Rho]", "^", "6"}]}], "+", 
          RowBox[{"\[Rho]", "^", "8"}], "+", 
          RowBox[{"\[Rho]", "^", "10"}], "-", 
          RowBox[{"16", " ", 
           RowBox[{"\[Rho]", "^", "5"}], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"a", "^", "2"}], "-", 
             RowBox[{"b", "^", "2"}]}], ")"}]}], "-", 
          RowBox[{"8", " ", 
           RowBox[{"\[Rho]", "^", "5"}], " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", "-", "b"}], ")"}], "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "5", " ", "\[Phi]"}], "]"}]}], "-", 
          RowBox[{"8", " ", 
           RowBox[{"\[Rho]", "^", "5"}], " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", "+", "b"}], ")"}], "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "5", " ", "\[Phi]"}], "]"}]}]}], ")"}]}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[Psi]Fig8", "[", 
       RowBox[{"a_", ",", "b_", ",", "s_", ",", 
        RowBox[{"w0_", ":", "0.001"}]}], "]"}], "[", 
      RowBox[{"r_", ",", "\[Phi]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Rho]", "=", 
         RowBox[{"r", "/", "w0"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{"-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Rho]", "/", "s"}], ")"}], "^", "2"}]}], "]"}], "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"8", " ", 
           RowBox[{"a", "^", "3"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"8", " ", 
           RowBox[{"a", "^", "3"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"16", " ", 
           RowBox[{"a", "^", "3"}], " ", 
           RowBox[{"\[Rho]", "^", "4"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"16", " ", 
           RowBox[{"a", "^", "3"}], " ", 
           RowBox[{"\[Rho]", "^", "4"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"8", " ", 
           RowBox[{"a", "^", "3"}], " ", 
           RowBox[{"\[Rho]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"8", " ", 
           RowBox[{"a", "^", "3"}], " ", 
           RowBox[{"\[Rho]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"12", " ", 
           RowBox[{"a", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "8"}]}], "+", 
          RowBox[{"24", " ", 
           RowBox[{"a", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}]}], "-", 
          RowBox[{"24", " ", 
           RowBox[{"a", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "2"}]}], "-", 
          RowBox[{"12", " ", 
           RowBox[{"a", "^", "2"}]}], "+", 
          RowBox[{"6", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"6", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"12", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "4"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"12", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "4"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"6", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"6", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "-", 
          RowBox[{"24", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "+", 
          RowBox[{"24", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "-", 
          RowBox[{"24", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "I"}], " ", "2", " ", "\[Phi]"}], "]"}]}], "-", 
          RowBox[{"24", " ", "a", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "2"}], " ", 
           RowBox[{"Exp", "[", 
            RowBox[{"I", " ", "2", " ", "\[Phi]"}], "]"}]}], "-", 
