Cell[CellGroupData[{

Cell["Overlap Integral ", "Subsection",
 CellChangeTimes->{{3.9682364841998177`*^9, 
  3.9682365005487185`*^9}},ExpressionUUID->"cf71e3c5-367d-49b2-91a6-\
3461a05db478"],

Cell[TextData[{
 "Now, we compute \n",
 Cell[BoxData[
  FormBox[
   TagBox[
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"\[Psi]1", "|", "\[Psi]2"}], "\[RightAngleBracket]"}], 
     "\[LongEqual]", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", 
       RowBox[{"2", " ", "\[Pi]"}]], 
      RowBox[{
       SubsuperscriptBox["\[Integral]", "0", "\[Infinity]"], 
       RowBox[{
        RowBox[{
         TemplateBox[{
           RowBox[{"\[Psi]1", "(", 
             RowBox[{"\[Rho]", ",", "\[Phi]"}], ")"}]},
          "Conjugate"], " ", 
         RowBox[{"\[Psi]2", "(", 
          RowBox[{"\[Rho]", ",", "\[Phi]"}], ")"}], " ", "\[Rho]"}], 
        RowBox[{"\[DifferentialD]", "\[Rho]"}], 
        RowBox[{"\[DifferentialD]", "\[Phi]"}]}]}]}]}],
    HoldForm], TraditionalForm]],
  CellChangeTimes->{{3.9682368709352417`*^9, 3.9682369588065844`*^9}, {
   3.968237042237663*^9, 3.968237098495513*^9}, {3.968237420423807*^9, 
   3.9682374711467648`*^9}, {3.968243889753067*^9, 3.9682439233993225`*^9}, {
   3.968330194577377*^9, 3.9683301992545977`*^9}, {3.968331049540561*^9, 
   3.968331055460313*^9}, {3.9687554016939545`*^9, 3.968755414452524*^9}, {
   3.96875942903922*^9, 3.968759432569833*^9}},
  EmphasizeSyntaxErrors->True,ExpressionUUID->
  "01f5c450-ca8d-474d-b5fd-62202d7cc3cb"],
 "\nWhere \[Psi]1 and \[Psi]2 refer to our knot wavefunctions. The parameters \
that we are using for each knot will be a=0.6, b=1, s=1.55.  These specific \
parameters were chosen as they are the same parameters that were used in Hugo\
\[CloseCurlyQuote]s thesis. These are NOT the same parameters for which we \
are performing the optimization!"
}], "Text",
 CellChangeTimes->{{3.968759474736625*^9, 3.9687595456486306`*^9}, {
  3.9687595832979507`*^9, 3.968759595709465*^9}, {3.968759690059918*^9, 
  3.968759697486777*^9}, {3.968759740726553*^9, 3.968759742814766*^9}, {
  3.968759821912266*^9, 3.9687598515389614`*^9}, {3.969097477594626*^9, 
  3.969097505299368*^9}},ExpressionUUID->"2f278787-a690-4c5e-adbc-\
2ccf68347ea4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"knotParamList", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"0.6", ",", " ", "1", ",", " ", "0.8"}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"--", " ", "a"}], ",", " ", "b", ",", " ", 
    RowBox[{"s", " ", "--"}]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.968759786805122*^9, 3.96875981008088*^9}, 
   3.9687652517096653`*^9, {3.9691214827588434`*^9, 3.9691214841953135`*^9}, {
   3.9691215848790865`*^9, 3.9691215886473427`*^9}, {3.9691216265579853`*^9, 
   3.969121628215984*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"df818385-c786-405a-bee9-5624d8425502"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{"Overlap", ",", "NOverlap"}], "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Overlap", "[", 
     RowBox[{
     "\[Psi]1_", ",", "pars1_List", ",", "\[Psi]2_", ",", "pars2_List"}], 
     "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"f1", ",", "f2", ",", "integrand"}], "}"}], ",", 
      RowBox[{
       RowBox[{"f1", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Psi]1", "@@", "pars1"}], ")"}], "[", 
         RowBox[{"\[Rho]", ",", "\[Phi]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"f2", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Psi]2", "@@", "pars2"}], ")"}], "[", 
         RowBox[{"\[Rho]", ",", "\[Phi]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"integrand", "=", 
        RowBox[{"ComplexExpand", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Conjugate", "[", "f1", "]"}], " ", "f2"}], ",", 
          RowBox[{"TargetFunctions", "->", 
           RowBox[{"{", 
            RowBox[{"Re", ",", "Im"}], "}"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Integrate", "[", 
        RowBox[{
         RowBox[{"integrand", " ", "\[Rho]"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Phi]", ",", "0", ",", 
           RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Rho]", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]}], 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"NOverlap", "[", 
    RowBox[{
    "\[Psi]1_", ",", "pars1_List", ",", "\[Psi]2_", ",", "pars2_List", ",", 
     RowBox[{"opts", ":", 
      RowBox[{"OptionsPattern", "[", "NIntegrate", "]"}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "f1", ",", "f2", ",", "integrand", ",", "a1", ",", "b1", ",", "s1", ",",
        "a2", ",", "b2", ",", "s2"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a1", ",", "b1", ",", "s1"}], "}"}], "=", "pars1"}], ";", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a2", ",", "b2", ",", "s2"}], "}"}], "=", "pars2"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"f1", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Psi]1", "@@", "pars1"}], ")"}], "[", 
        RowBox[{"\[Rho]", ",", "\[Phi]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"f2", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Psi]2", "@@", "pars2"}], ")"}], "[", 
        RowBox[{"\[Rho]", ",", "\[Phi]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"integrand", "=", 
       RowBox[{"ComplexExpand", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "[", "f1", "]"}], " ", "f2"}], ",", 
         RowBox[{"TargetFunctions", "->", 
          RowBox[{"{", 
           RowBox[{"Re", ",", "Im"}], "}"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"integrand", " ", "\[Rho]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Phi]", ",", "0", ",", 
          RowBox[{"2", " ", "Pi"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Rho]", ",", "0", ",", "Infinity"}], "}"}], ",", 
        RowBox[{"Method", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<GlobalAdaptive\>\"", ",", 
           RowBox[{"\"\<SymbolicPreprocessing\>\"", "->", "0"}]}], "}"}]}], 
        ",", 
        RowBox[{"WorkingPrecision", "->", "50"}], ",", 
        RowBox[{"AccuracyGoal", "->", "12"}], ",", 
        RowBox[{"PrecisionGoal", "->", "12"}], ",", "opts"}], "]"}]}]}], 
    "]"}]}], ";"}], "\n"}], "Input",
 CellChangeTimes->{{3.9683233948059053`*^9, 3.9683233948059053`*^9}, 
   3.9683288577649994`*^9, {3.968328955378152*^9, 3.968328957648671*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"97945abd-66c0-4330-8490-ddcb47690111"],

Cell["\<\
It will be cool to compute the normalized wavefunction overlap. We can use \
the overlap function to compute the normalization constant of the wave \
function. \
\>", "Text",
 CellChangeTimes->{{3.9682445588072653`*^9, 3.9682445786256723`*^9}, {
  3.968244687556539*^9, 3.9682446898330297`*^9}, {3.9683216946240635`*^9, 
