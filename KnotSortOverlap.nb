     RowBox[{"Overlap", "[", 
      RowBox[{
      "\[Psi]Cinquefoil", ",", "knotParamList", ",", "\[Psi]Cinquefoil", ",", 
       " ", "knotParamList"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Fig8Norm", " ", "=", " ", 
     RowBox[{"Overlap", "[", 
      RowBox[{
      "\[Psi]Fig8", ",", "knotParamList", ",", "\[Psi]Fig8", ",", " ", 
       "knotParamList"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.968321740237173*^9, 3.9683218900698013`*^9}, {
  3.9683234152326937`*^9, 3.968323417571018*^9}, {3.9683304415338383`*^9, 
