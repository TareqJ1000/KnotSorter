Cell["Trefoil and Cinquefoil", "Subsubsection",
 CellChangeTimes->{{3.9682439364463997`*^9, 
  3.9682439424051228`*^9}},ExpressionUUID->"90a32048-a2fc-4e70-92c5-\
e7b9a79e5455"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TrefCinque", " ", "=", 
  RowBox[{"Abs", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", "TrefNorm", "]"}]}], " ", "*", " ", 
      RowBox[{"1", "/", 
       RowBox[{"Sqrt", "[", "CinqueNorm", "]"}]}]}], ")"}], "*", 
    RowBox[{"Overlap", "[", 
     RowBox[{
     "\[Psi]Trefoil", ",", " ", "knotParamList", ",", " ", "\[Psi]Cinquefoil",
       ",", " ", "knotParamList"}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.968243947324687*^9, 3.9682440088473797`*^9}, {
