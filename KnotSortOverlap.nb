           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "8"}]}], "-", 
          RowBox[{"6", " ", 
           RowBox[{"b", "^", "2"}], " ", 
           RowBox[{"\[Rho]", "^", "6"}]}], "+", 
          RowBox[{"6", " ", 
           RowBox[{"b", "^", "2"}], " ", 
